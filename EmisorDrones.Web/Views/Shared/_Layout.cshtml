<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Emisor de Drones</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Consolas, Monaco, 'Courier New', monospace;
            background: #ffffff;
            min-height: 100vh;
            color: #000000;
        }

        nav {
            background-color: #ffffff;
            border-bottom: 1px solid #000000;
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 2rem;
            max-width: 1200px;
            margin: 0 auto;
            align-items: center;
        }

        nav a {
            color: #000000;
            text-decoration: none;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border: 1px solid #000000;
            border-radius: 0;
            display: inline-block;
        }

        nav a:hover {
            background-color: #000000;
            color: #ffffff;
        }

        .nav-inline-form {
            margin: 0;
            padding: 0;
            background: transparent;
        }

        .nav-link-button {
            color: #000000;
            text-decoration: none;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 0;
            border: 1px solid #000000;
            background: #ffffff;
            cursor: pointer;
            font-size: 1rem;
            font-family: Consolas, Monaco, 'Courier New', monospace;
        }

        .nav-link-button:hover {
            background-color: #000000;
            color: #ffffff;
        }

        .container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 2rem;
        }

        .main-layout {
            background: #ffffff;
            border: 1px solid #000000;
            border-radius: 0;
            padding: 2rem;
            min-height: 60vh;
        }

        h1 {
            color: #000000;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid #000000;
            padding-bottom: 0.5rem;
        }

        h2 {
            color: #000000;
            margin-top: 1.5rem;
            margin-bottom: 1rem;
        }

        .card {
            background: #ffffff;
            color: #000000;
            padding: 1.5rem;
            border-radius: 0;
            border: 1px solid #000000;
            margin-bottom: 1rem;
        }

        .card-title {
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 0.5rem;
        }

        .card-value {
            font-size: 2rem;
            font-weight: bold;
        }

        .btn {
            padding: 0.75rem 1.5rem;
            border: 1px solid #000000;
            border-radius: 0;
            cursor: pointer;
            font-weight: bold;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            font-family: Consolas, Monaco, 'Courier New', monospace;
        }

        .btn-primary {
            background-color: #ffffff;
            color: #000000;
        }

        .btn-primary:hover {
            background-color: #000000;
            color: #ffffff;
        }

        .btn-secondary {
            background-color: #ffffff;
            color: #000000;
        }

        .btn-secondary:hover {
            background-color: #000000;
            color: #ffffff;
        }

        .btn-danger {
            background-color: #ffffff;
            color: #000000;
        }

        .btn-danger:hover {
            background-color: #000000;
            color: #ffffff;
        }

        .btn-small {
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
        }

        form {
            background-color: #ffffff;
            padding: 1.5rem;
            border-radius: 0;
            border: 1px solid #000000;
            margin: 1rem 0;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: bold;
            color: #000000;
        }

        input[type="text"],
        input[type="number"],
        input[type="email"],
        input[type="password"],
        textarea,
        select {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid #000000;
            border-radius: 0;
            font-family: inherit;
            font-size: 1rem;
        }

        input:focus,
        textarea:focus,
        select:focus {
            outline: none;
            border-color: #000000;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin: 1rem 0;
            background: white;
        }

        th {
            background-color: #ffffff;
            color: #000000;
            padding: 1rem;
            text-align: left;
            font-weight: bold;
            border: 1px solid #000000;
        }

        td {
            padding: 1rem;
            border: 1px solid #000000;
        }

        tr:hover {
            background-color: #f2f2f2;
        }

        .alert {
            padding: 1rem;
            border-radius: 4px;
            margin-bottom: 1rem;
        }

        .alert-success {
            background-color: #ffffff;
            color: #000000;
            border: 1px solid #000000;
        }

        .alert-error {
            background-color: #ffffff;
            color: #000000;
            border: 1px solid #000000;
        }

        .alert-info {
            background-color: #ffffff;
            color: #000000;
            border: 1px solid #000000;
        }

        footer {
            background-color: #ffffff;
            color: #000000;
            text-align: center;
            padding: 2rem;
            margin-top: 3rem;
            border-top: 1px solid #000000;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin: 1rem 0;
        }

        .text-center {
            text-align: center;
        }

        .text-muted {
            color: #000000;
        }

        .mb-2 {
            margin-bottom: 0.5rem;
        }

        .mt-2 {
            margin-top: 0.5rem;
        }

        .ml-2 {
            margin-left: 0.5rem;
        }
    </style>
</head>
<body>
    <nav>
        <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/Planificador/CargarXmlEntrada">Cargar XML</a></li>
            <li><a href="/Home/GestionarDrones">Gestionar Drones</a></li>
            <li><a href="/Planificador/GestionMensajes">Gestionar Mensajes</a></li>
            <li><a href="/Planificador/VerSistemaGrafico">Gráfico Sistema</a></li>
            <li><a href="/Planificador/VerInstruccionesGraficas">Gráfico Timeline</a></li>
            <li>
                <form class="nav-inline-form" method="post" action="/Home/InicializarSistema">
                    <button type="submit" class="nav-link-button">Inicializar Sistema</button>
                </form>
            </li>
            <li><a href="/Home/Acerca">Acerca de</a></li>
        </ul>
    </nav>

    <div class="container">
        <div class="main-layout">
            @RenderBody()
        </div>
    </div>

    <footer>
        <p>Emisor de Drones - Proyecto 2 IPC2</p>
    </footer>
</body>
</html>



