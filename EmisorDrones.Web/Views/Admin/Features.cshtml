@using EmisorDrones.CoreBusiness.Configuration

@{
    ViewData["Title"] = "Matriz de Funcionalidades";
}

<h1>📊 Matriz de Funcionalidades por Release</h1>

<p style="margin-bottom: 2rem;">esta matriz muestra en qué momento (release) cada funcionalidad se introduce al sistema.</p>

<table style="width: 100%; border-collapse: collapse; margin: 2rem 0;">
    <thead style="background-color: #667eea; color: white;">
        <tr>
            <th style="padding: 1rem; text-align: left; border: 1px solid #ddd;">Funcionalidad</th>
            <th style="padding: 1rem; text-align: center; border: 1px solid #ddd; background-color: #d4edda;">Release 1</th>
            <th style="padding: 1rem; text-align: center; border: 1px solid #ddd;">Release 2</th>
            <th style="padding: 1rem; text-align: center; border: 1px solid #ddd;">Release 3</th>
            <th style="padding: 1rem; text-align: center; border: 1px solid #ddd;">Release 4</th>
        </tr>
    </thead>
    <tbody>
        @{
            var releases = new[] {
                FeatureFlags.Release.Release1,
                FeatureFlags.Release.Release2,
                FeatureFlags.Release.Release3,
                FeatureFlags.Release.Release4
            };

            foreach (FeatureFlags.Feature feature in Enum.GetValues(typeof(FeatureFlags.Feature)).Cast<FeatureFlags.Feature>().OrderBy(f => (int)f))
            {
                int featureRelease = (int)feature;
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 1rem; border: 1px solid #ddd;"><strong>@FeatureFlags.GetDescription(feature)</strong></td>
                    @foreach (var release in releases)
                    {
                        int releaseNum = (int)release;
                        bool available = featureRelease == releaseNum;
                        <td style="padding: 1rem; text-align: center; border: 1px solid #ddd; background-color: @(available ? "#d4edda" : featureRelease < releaseNum ? "#fff" : "#f0f0f0");">
                            @if (featureRelease <= releaseNum)
                            {
                                <span style="color: green;">✓</span>
                            }
                            else
                            {
                                <span style="color: #ccc;">-</span>
                            }
                        </td>
                    }
                </tr>
            }
        }
    </tbody>
</table>

<hr style="margin: 2rem 0;">

<h2>📖 Leyenda</h2>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
    <div style="background-color: #d4edda; padding: 1rem; border-radius: 4px; border-left: 4px solid #28a745;">
        <p><strong>✓ (Celda Verde)</strong></p>
        <p>funcionalidad se introduce en este release</p>
    </div>
    <div style="background-color: #fff; padding: 1rem; border-radius: 4px; border-left: 4px solid #999;">
        <p><strong>✓ (Celda Blanca)</strong></p>
        <p>funcionalidad ya está disponible (introducida en release anterior)</p>
    </div>
    <div style="background-color: #f0f0f0; padding: 1rem; border-radius: 4px; border-left: 4px solid #ccc;">
        <p><strong>- (Celda Gris)</strong></p>
        <p>funcionalidad no está disponible aún</p>
    </div>
</div>

<hr style="margin: 2rem 0;">

<a href="/Admin/Dashboard" class="btn btn-secondary">← volver al panel</a>
