@using EmisorDrones.CoreBusiness.Configuration

@{
    ViewData["Title"] = "Panel de Administración - Feature Flags";
}

<h1>⚙️ Panel de Administración</h1>

<div style="background-color: #fff3cd; padding: 1.5rem; border-radius: 4px; border-left: 4px solid #ff9800; margin-bottom: 2rem;">
    <strong>⚡ Release Flags:</strong> desde aquí puedes cambiar qué release está activo. esto habilitará/deshabilitará funcionalidades según el plan de desarrollo.
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
}

<h2>📍 Release Actual</h2>

<div class="grid">
    <div class="card">
        <div class="card-title">Release Activo</div>
        <div class="card-value">@ViewBag.CurrentRelease</div>
    </div>
</div>

<h2>🔧 Cambiar Release</h2>

<form method="POST" action="/Admin/ChangeRelease" style="background: #f8f9fa; padding: 1.5rem; border-radius: 4px; display: inline-block;">
    <div class="form-group" style="margin-bottom: 1rem;">
        <label for="releaseId"><strong>selecciona un release:</strong></label>
        <select id="releaseId" name="releaseId" style="margin-top: 0.5rem;">
            @foreach (FeatureFlags.Release release in ViewBag.AvailableReleases)
            {
                <option value="@((int)release)" @(release == ViewBag.CurrentRelease ? "selected" : "")>
                    @release - @GetDescription(release)
                </option>
            }
        </select>
    </div>
    <button type="submit" class="btn btn-primary">cambiar release</button>
</form>

<hr style="margin: 2rem 0;">

<h2>📋 Detalles de Cada Release</h2>

<div style="background-color: #d4edda; padding: 1.5rem; border-radius: 4px; margin-bottom: 1.5rem; border-left: 4px solid #28a745;">
    <h3>Release 1: Fundación</h3>
    <p>infraestructura base, TDAs personalizados y gestión simple de drones</p>
    <ul style="margin-left: 2rem;">
        <li>✓ gestionar drones (crear, ver, eliminar)</li>
        <li>✓ ver historial de instrucciones</li>
        <li>✓ dashboard con estado del sistema</li>
        <li>✓ validaciones de altura y capacidad</li>
    </ul>
</div>

<div style="background-color: #def1f7; padding: 1.5rem; border-radius: 4px; margin-bottom: 1.5rem; border-left: 4px solid #667eea;">
    <h3>Release 2: Sistemas de Mapeo</h3>
    <p>configuración de letras a alturas y visualización del sistema</p>
    <ul style="margin-left: 2rem;">
        <li>📍 gestionar sistemas de drones</li>
        <li>📍 mapear letras a alturas específicas</li>
        <li>📍 visualizar gráficos en graphviz</li>
        <li>📍 cargar/guardar configuración en XML</li>
    </ul>
</div>

<div style="background-color: #def1f7; padding: 1.5rem; border-radius: 4px; margin-bottom: 1.5rem; border-left: 4px solid #667eea;">
    <h3>Release 3: Procesamiento de Mensajes</h3>
    <p>algoritmo de optimización y generación de instrucciones</p>
    <ul style="margin-left: 2rem;">
        <li>📍 procesar mensajes de texto</li>
        <li>📍 calcular instrucciones óptimas (tiempo mínimo)</li>
        <li>📍 algoritmo de coordinación multi-dron</li>
        <li>📍 simulador de pre-visualización</li>
    </ul>
</div>

<div style="background-color: #def1f7; padding: 1.5rem; border-radius: 4px; margin-bottom: 1.5rem; border-left: 4px solid #667eea;">
    <h3>Release 4: Visualización y Exportación</h3>
    <p>simulación visual, gráficos avanzados y exportación de resultados</p>
    <ul style="margin-left: 2rem;">
        <li>📍 simulación paso a paso visual</li>
        <li>📍 gráficos de timeline (segundo a segundo)</li>
        <li>📍 heatmap de ocupación de alturas</li>
        <li>📍 exportar resultados a XML detallado</li>
        <li>📍 estadísticas de ejecución</li>
    </ul>
</div>

<hr style="margin: 2rem 0;">

<h2>🎯 Funcionalidades por Release</h2>

<a href="/Admin/Features" class="btn btn-secondary">ver matriz completa de funcionalidades</a>

@{
    string GetDescription(FeatureFlags.Release release)
    {
        return release switch
        {
            FeatureFlags.Release.Release1 => "Fundación - TDAs e Infraestructura",
            FeatureFlags.Release.Release2 => "Sistemas de Mapeo",
            FeatureFlags.Release.Release3 => "Procesamiento de Mensajes",
            FeatureFlags.Release.Release4 => "Visualización Avanzada",
            _ => "Desconocido"
        };
    }
}
