@model Drone[]

@{
    ViewData["Title"] = "Gestin de Drones";
}

<h1>Gestin de Drones</h1>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-error">
        @TempData["Error"]
    </div>
}

<div style="margin-bottom: 2rem;">
    <a href="/Home/AgregarDron" class="btn btn-primary">+ Agregar Nuevo Dron</a>
</div>

@if (Model != null && Model.Length >0)
{
    <h2>Drones Registrados (@Model.Length)</h2>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Estado</th>
                <th>Altura Actual</th>
                <th>Rango (Min-Max)</th>
                <th>Emisiones</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dron in Model)
            {
                <tr>
                    <td>
                        <strong>Dron #@dron.Id</strong>
                    </td>
                    <td>
                        <span style="background-color: @(dron.Activo ? "#d4edda" : "#f8d7da"); padding: 0.25rem 0.5rem; border-radius: 4px; color: @(dron.Activo ? "#155724" : "#721c24");">
                            @(dron.Activo ? " Activo" : " Inactivo")
                        </span>
                    </td>
                    <td>@dron.AlturaActual m</td>
                    <td>@dron.AlturaMinima - @dron.AlturaMaxima m</td>
                    <td>@dron.VecesEmitioLuz veces</td>
                    <td>
                        <a href="/Home/DetallesDron/@dron.Id" class="btn btn-secondary btn-small">Ver Detalles</a>
                        <form method="POST" action="/Home/EliminarDron" style="display: inline; margin: 0;">
                            <input type="hidden" name="id" value="@dron.Id">
                            <button type="submit" class="btn btn-danger btn-small" onclick="return confirm('Est seguro de eliminar el dron #@dron.Id?');">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info text-center" style="padding: 2rem;">
        <p style="font-size: 1.1rem;">No hay drones registrados</p>
        <p class="text-muted">Comience agregando un nuevo dron para empezar</p>
        <a href="/Home/AgregarDron" class="btn btn-primary mt-2">Agregar Primer Dron</a>
    </div>
}



